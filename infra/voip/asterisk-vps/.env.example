# Copie pra .env e preencha. O setup.sh lê estas variáveis pra gerar os configs.

# Domínio do PABX (DNS A apontando pra ESTE servidor, "DNS only" / sem proxy CF):
VOIP_DOMAIN=voip.yugochat.com.br

# IPv4 PÚBLICO deste servidor (não CGNAT). Usado no coturn/Asterisk p/ mídia.
PUBLIC_IP=5.78.212.244

# URL pública da API do yugo (na VPS local, via Cloudflare). O sync-config.sh
# consulta aqui pra montar o pjsip.conf dinâmico (endpoints + trunks).
API_URL=https://yugochat.com.br

# Segredo combinado com a API (MESMO valor de VOIP_FS_SECRET no .env.production
# do yugo — mantido o nome FS_SECRET por compatibilidade).
VOIP_FS_SECRET=TROQUE_ESTE_SEGREDO

# Credenciais do coturn (use as MESMAS em VOIP_TURN_USER/PASS no .env.production
# do yugo).
TURN_USER=yugo
TURN_PASS=TROQUE_ESTA_SENHA
