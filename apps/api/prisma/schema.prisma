// schema.prisma - subset do schema SQL real, focado no que a API consome.
// Fonte da verdade: packages/db/sql/*.sql. Atualizar via `prisma db pull`.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ================ COBRANCA (DUNNING) ================
model DunningRule {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  name            String
  daysAfterDue    Int      @map("days_after_due")
  channel         String   @default("whatsapp")
  templateText    String   @map("template_text")
  isActive        Boolean  @default(true) @map("is_active")
  displayOrder    Int      @default(0) @map("display_order")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @map("updated_at")

  @@unique([organizationId, daysAfterDue])
  @@map("dunning_rules")
}

model DunningEvent {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  creditAccountId String   @map("credit_account_id") @db.Uuid
  installmentId   String   @map("installment_id") @db.Uuid
  ruleId          String?  @map("rule_id") @db.Uuid
  daysOverdue     Int      @map("days_overdue")
  channel         String
  message         String?
  status          String   @default("sent")
  detail          String?
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("dunning_events")
}

// ================ PAGAMENTOS POR ORG ================
model OrganizationIntegration {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  provider        String
  label           String?
  accessToken     String?  @map("access_token")
  publicKey       String?  @map("public_key")
  webhookSecret   String?  @map("webhook_secret")
  config          Json     @default("{}")
  status          String   @default("disabled")
  lastPingAt      DateTime? @map("last_ping_at")
  lastPingStatus  String?  @map("last_ping_status")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @map("updated_at")
  updatedByUserId String?  @map("updated_by_user_id") @db.Uuid

  @@unique([organizationId, provider])
  @@map("organization_integrations")
}

model MessageTemplate {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  channel         String
  code            String
  name            String
  category        String   @default("info")
  subject         String?
  body            String
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @map("updated_at")

  @@unique([organizationId, channel, code])
  @@map("message_templates")
}

model Supplier {
  id                String   @id @default(uuid()) @db.Uuid
  organizationId    String   @map("organization_id") @db.Uuid
  type              String
  name              String
  document          String?
  councilNumber     String?  @map("council_number")
  phone             String?
  email             String?
  payoutMode        String   @default("fixed") @map("payout_mode")
  payoutFixedCents  BigInt?  @map("payout_fixed_cents")
  payoutPercent     Decimal? @map("payout_percent") @db.Decimal(5, 2)
  pixKey            String?  @map("pix_key")
  bankInfo          Json     @default("{}") @map("bank_info")
  // valor único por peça produzida (costureira). Multiplicado pelo total de peças
  // do roster do pedido ao marcar "pronto" no portal. 0 = sem cálculo automático.
  pricePerPieceCents BigInt   @default(0) @map("price_per_piece_cents")
  status            String   @default("active")
  passwordHash      String?  @map("password_hash")
  mustResetPassword Boolean  @default(true) @map("must_reset_password")
  portalLastLoginAt DateTime? @map("portal_last_login_at")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @default(now()) @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  sessions          SupplierSession[]

  @@map("suppliers")
}

model SupplierSession {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  supplierId      String   @map("supplier_id") @db.Uuid
  tokenHash       String   @unique @map("token_hash")
  ipAddress       String?  @map("ip_address") @db.Inet
  userAgent       String?  @map("user_agent")
  expiresAt       DateTime @map("expires_at")
  revokedAt       DateTime? @map("revoked_at")
  createdAt       DateTime @default(now()) @map("created_at")

  supplier        Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@map("supplier_sessions")
}

model LabBatch {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  storeId         String?  @map("store_id") @db.Uuid
  labSupplierId   String?  @map("lab_supplier_id") @db.Uuid
  code            String
  status          String   @default("pendente")
  courierUserId   String?  @map("courier_user_id") @db.Uuid
  sentAt          DateTime? @map("sent_at")
  receivedAt      DateTime? @map("received_at")
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @map("updated_at")

  orders          LensOrder[]

  @@unique([organizationId, code])
  @@map("lab_batches")
}

model LensOrder {
  id                 String   @id @default(uuid()) @db.Uuid
  organizationId     String   @map("organization_id") @db.Uuid
  storeId            String   @map("store_id") @db.Uuid
  customerId         String?  @map("customer_id") @db.Uuid
  saleId             String?  @map("sale_id") @db.Uuid
  doctorSupplierId   String?  @map("doctor_supplier_id") @db.Uuid
  labSupplierId      String?  @map("lab_supplier_id") @db.Uuid
  labBatchId         String?  @map("lab_batch_id") @db.Uuid
  frameProductId     String?  @map("frame_product_id") @db.Uuid
  lensProductId      String?  @map("lens_product_id") @db.Uuid
  osNumber           String?  @map("os_number")
  prescription       Json     @default("{}")
  examAttachmentUrl  String?  @map("exam_attachment_url")
  status             String   @default("medido")
  late               Boolean  @default(false)
  expectedAt         DateTime? @map("expected_at")
  customerPriceCents BigInt?  @map("customer_price_cents")
  labCostCents       BigInt?  @map("lab_cost_cents")
  notes              String?
  productDescription String?  @map("product_description")
  productPhotoUrl    String?  @map("product_photo_url")
  nfNumber           String?  @map("nf_number")
  nfUrl              String?  @map("nf_url")
  nfAttachedAt       DateTime? @map("nf_attached_at")
  deliverySignatureUrl String? @map("delivery_signature_url")
  deliveryConfirmedAt  DateTime? @map("delivery_confirmed_at")
  sellerUserId       String?  @map("seller_user_id") @db.Uuid
  createdByUserId    String?  @map("created_by_user_id") @db.Uuid
  measuredAt         DateTime? @map("measured_at")
  requestedAt        DateTime? @map("requested_at")
  arrivedAt          DateTime? @map("arrived_at")
  experienceSurveySentAt DateTime? @map("experience_survey_sent_at")
  notifiedAt         DateTime? @map("notified_at")
  deliveredAt        DateTime? @map("delivered_at")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @default(now()) @map("updated_at")

  batch              LabBatch? @relation(fields: [labBatchId], references: [id])

  @@map("lens_orders")
}

model SatisfactionSurvey {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  storeId         String?  @map("store_id") @db.Uuid
  customerId      String?  @map("customer_id") @db.Uuid
  kind            String
  refId           String?  @map("ref_id") @db.Uuid
  stage           String?
  token           String   @unique
  sellerUserId    String?  @map("seller_user_id") @db.Uuid
  npsScore        Int?     @map("nps_score")
  sellerRating    Int?     @map("seller_rating")
  comment         String?
  channel         String?
  sentAt          DateTime? @map("sent_at")
  respondedAt     DateTime? @map("responded_at")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("satisfaction_surveys")
}

model SupplierSettlement {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  supplierId      String   @map("supplier_id") @db.Uuid
  periodStart     DateTime? @map("period_start") @db.Date
  periodEnd       DateTime? @map("period_end") @db.Date
  totalCents      BigInt   @default(0) @map("total_cents")
  status          String   @default("pending")
  paidAt          DateTime? @map("paid_at")
  paymentMethod   String?  @map("payment_method")
  paymentId       String?  @map("payment_id")
  proofUrl        String?  @map("proof_url")
  notes           String?
  createdByUserId String?  @map("created_by_user_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @map("updated_at")

  items           SettlementItem[]

  @@map("supplier_settlements")
}

model SettlementItem {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  settlementId    String   @map("settlement_id") @db.Uuid
  sourceType      String   @map("source_type")
  sourceId        String?  @map("source_id") @db.Uuid
  description     String
  amountCents     BigInt   @default(0) @map("amount_cents")
  createdAt       DateTime @default(now()) @map("created_at")

  settlement      SupplierSettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)

  @@map("settlement_items")
}

model CommissionPayout {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  sellerUserId    String   @map("seller_user_id") @db.Uuid
  periodStart     DateTime? @map("period_start") @db.Date
  periodEnd       DateTime? @map("period_end") @db.Date
  salesCount      Int      @default(0) @map("sales_count")
  baseCents       BigInt   @default(0) @map("base_cents")
  commissionPct   Decimal? @map("commission_pct") @db.Decimal(5, 2)
  totalCents      BigInt   @default(0) @map("total_cents")
  status          String   @default("pending")
  paidAt          DateTime? @map("paid_at")
  paymentMethod   String?  @map("payment_method")
  paymentId       String?  @map("payment_id")
  proofUrl        String?  @map("proof_url")
  notes           String?
  createdByUserId String?  @map("created_by_user_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @map("updated_at")

  @@map("commission_payouts")
}

model OrganizationSmtpSettings {
  organizationId  String   @id @map("organization_id") @db.Uuid
  host            String?
  port            Int      @default(587)
  secure          Boolean  @default(false)
  username        String?
  password        String?
  fromName        String?  @map("from_name")
  fromEmail       String?  @map("from_email")
  replyTo         String?  @map("reply_to")
  enabled         Boolean  @default(false)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @map("updated_at")

  @@map("organization_smtp_settings")
}

model PaymentAttempt {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  installmentId   String   @map("installment_id") @db.Uuid
  method          String
  amountCents     BigInt   @map("amount_cents")
  attemptNumber   Int      @default(1) @map("attempt_number")
  status          String   @default("pending")
  mpPaymentId     String?  @map("mp_payment_id")
  mpStatusDetail  String?  @map("mp_status_detail")
  errorMessage    String?  @map("error_message")
  nextRetryAt     DateTime? @map("next_retry_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @map("updated_at")

  @@map("payment_attempts")
}

// ================ CREDIARIO ================
model Product {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  storeId         String?  @map("store_id") @db.Uuid
  sku             String?
  name            String
  description     String?
  category        String?
  imageUrl        String?  @map("image_url")
  priceCashCents              Int? @map("price_cash_cents")
  priceCardFullCents          Int? @map("price_card_full_cents")
  priceCardInstallmentsCents  Int? @map("price_card_installments_cents")
  priceCreditCents            Int? @map("price_credit_cents")
  creditInterestPct           Float? @map("credit_interest_pct")
  earlyPaymentDiscountPct     Float? @map("early_payment_discount_pct")
  maxInstallments             Int? @map("max_installments")
  stockQty        Int      @default(0) @map("stock_qty")
  minStockQty     Int      @default(0) @map("min_stock_qty")
  trackStock      Boolean  @default(false) @map("track_stock")
  isActive        Boolean  @default(true) @map("is_active")
  showInCatalog   Boolean  @default(true) @map("show_in_catalog")
  costCents       Int?     @map("cost_cents")
  laboratorySupplierId String? @map("laboratory_supplier_id") @db.Uuid
  ncm             String?
  cfop            String?
  cest            String?
  origem          Int      @default(0)
  unidade         String   @default("UN")
  cst             String?
  csosn           String?
  aliqIcms        Decimal? @map("aliq_icms") @db.Decimal(5, 2)
  deletedAt       DateTime? @map("deleted_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @map("updated_at")

  @@map("products")
}

model FiscalConfig {
  id              String    @id @default(uuid()) @db.Uuid
  organizationId  String    @unique @map("organization_id") @db.Uuid
  cnpj            String?
  ie              String?
  im              String?
  razaoSocial     String?   @map("razao_social")
  nomeFantasia    String?   @map("nome_fantasia")
  crt             Int       @default(1)
  uf              String?
  cmun            String?
  municipio       String?
  logradouro      String?
  numero          String?
  complemento     String?
  bairro          String?
  cep             String?
  fone            String?
  ambiente        Int       @default(2)
  nfceSerie       Int       @default(1) @map("nfce_serie")
  nfceNext        Int       @default(1) @map("nfce_next")
  cscId           String?   @map("csc_id")
  cscTokenEnc     String?   @map("csc_token_enc")
  nfceUrlHom      String?   @map("nfce_url_hom")
  nfceUrlProd     String?   @map("nfce_url_prod")
  nfeSerie        Int       @default(1) @map("nfe_serie")
  nfeNext         Int       @default(1) @map("nfe_next")
  nfeUrlHom       String?   @map("nfe_url_hom")
  nfeUrlProd      String?   @map("nfe_url_prod")
  // NFS-e (Sistema Nacional / Sefin Nacional via API mTLS)
  nfseEnabled     Boolean   @default(false) @map("nfse_enabled")
  nfseAmbiente    Int?      @map("nfse_ambiente")     // null=usa ambiente global; 1=Produção; 2=Homologação
  nfseMunicipio   String?   @map("nfse_municipio")    // código IBGE (7) do município emissor
  nfseSerie       Int       @default(1) @map("nfse_serie")
  nfseNext        Int       @default(1) @map("nfse_next")     // nº DPS sequencial (atômico)
  nfseUrlHom      String?   @map("nfse_url_hom")       // base Sefin Nacional (produção restrita)
  nfseUrlProd     String?   @map("nfse_url_prod")
  nfseOpSimpNac   Int       @default(1) @map("nfse_op_simp_nac")  // 1=Não optante,2=Optante MEI,3=Optante
  nfseRegEspTrib  Int       @default(0) @map("nfse_reg_esp_trib") // regime especial de tributação
  nfseCodServico  String?   @map("nfse_cod_servico")   // código de tributação nacional padrão (6) — LC116/subitem
  nfseCnae        String?   @map("nfse_cnae")
  nfseAliqIss     Float?    @map("nfse_aliq_iss")      // alíquota ISS padrão (%)
  a1CertKey       String?   @map("a1_cert_key")
  a1PassEnc       String?   @map("a1_pass_enc")
  a1Subject       String?   @map("a1_subject")
  a1NotAfter      DateTime? @map("a1_not_after")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @default(now()) @map("updated_at")

  @@map("fiscal_config")
}

// Tabelas de referência fiscal (globais, oficiais) — auto-preenchimento do produto.
model Ncm {
  codigo     String   @id
  descricao  String
  updatedAt  DateTime @default(now()) @map("updated_at")
  @@map("ncm")
}
model Cest {
  id         String  @id @default(uuid()) @db.Uuid
  cest       String
  ncm        String?
  descricao  String?
  @@unique([cest, ncm])
  @@index([ncm])
  @@map("cest")
}
model ServicoLc116 {
  codigo     String @id
  descricao  String
  @@map("servico_lc116")
}

model FiscalDocument {
  id              String    @id @default(uuid()) @db.Uuid
  organizationId  String    @map("organization_id") @db.Uuid
  storeId         String?   @map("store_id") @db.Uuid
  saleId          String?   @map("sale_id") @db.Uuid
  modelo          String    @default("65")     // 65=NFC-e, 55=NF-e, 99=NFS-e (DPS)
  serie           Int?
  numero          Int?
  chave           String?
  ambiente        Int       @default(2)
  status          String    @default("rascunho")
  protocolo       String?
  motivo          String?
  totalCents      Int?      @map("total_cents")
  xmlKey          String?   @map("xml_key")
  danfeKey        String?   @map("danfe_key")
  qrUrl           String?   @map("qr_url")
  cancelMotivo    String?   @map("cancel_motivo")
  authorizedAt    DateTime? @map("authorized_at")
  // NFS-e
  nDps              Int?      @map("n_dps")        // nº da DPS
  competencia       DateTime? @db.Date             // competência (mês do serviço)
  nfseXmlKey        String?   @map("nfse_xml_key") // XML da NFS-e gerada (resposta)
  productionOrderId String?   @map("production_order_id") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @default(now()) @map("updated_at")

  @@index([organizationId, createdAt])
  @@index([saleId])
  @@map("fiscal_document")
}

model ProductionOrder {
  id               String   @id @default(uuid()) @db.Uuid
  organizationId   String   @map("organization_id") @db.Uuid
  storeId          String?  @map("store_id") @db.Uuid
  customerId       String?  @map("customer_id") @db.Uuid
  shortCode        String?  @unique @map("short_code")
  contactName      String   @map("contact_name")
  contactPhone     String?  @map("contact_phone")
  contactEmail     String?  @map("contact_email")
  status           String   @default("novo")
  artStatus        String   @default("aguardando_arquivos") @map("art_status")
  delivery         Boolean  @default(false)
  dueDate          DateTime? @map("due_date") @db.Date
  totalCents       BigInt   @default(0) @map("total_cents")
  discountCents    BigInt   @default(0) @map("discount_cents")
  discountAuthorizedBy String? @map("discount_authorized_by")
  downPaymentCents BigInt   @default(0) @map("down_payment_cents")
  paymentStatus    String   @default("none") @map("payment_status")
  paymentMethod    String?  @map("payment_method")
  needsInvoice     Boolean  @default(false) @map("needs_invoice")
  nfUrl            String?  @map("nf_url")
  nfIssuedAt       DateTime? @map("nf_issued_at")
  nfKey            String?  @map("nf_key")
  nfNumber         String?  @map("nf_number")
  nfAuthorizedBy   String?  @map("nf_authorized_by")
  fiscalCpf        String?  @map("fiscal_cpf")
  fiscalAddress    String?  @map("fiscal_address")
  fiscalBirthDate  DateTime? @map("fiscal_birth_date") @db.Date
  notes            String?
  sellerUserId     String?  @map("seller_user_id") @db.Uuid
  createdByUserId  String?  @map("created_by_user_id") @db.Uuid
  readyNotifiedAt  DateTime? @map("ready_notified_at")
  producaoNotifiedAt DateTime? @map("producao_notified_at")
  entregaNotifiedAt  DateTime? @map("entrega_notified_at")
  paymentProofUrl  String?  @map("payment_proof_url")
  paymentProofAt   DateTime? @map("payment_proof_at")
  saldoReminderAt  DateTime? @map("saldo_reminder_at")
  batchId          String?  @map("batch_id") @db.Uuid
  fabricConsumedAt DateTime? @map("fabric_consumed_at")
  // Costureira atribuída (Supplier type="costureira"). Ela vê essa OS no portal.
  assignedSupplierId    String?  @map("assigned_supplier_id") @db.Uuid
  // Momento em que a costureira marcou "Pedido pronto" no portal.
  producedAt            DateTime? @map("produced_at")
  // Snapshot do valor a pagar à costureira (= price_per_piece × qty do roster).
  // Congelado no instante do "pronto" pra histórico não mudar se a config mexer.
  productionPriceCents  BigInt?  @map("production_price_cents")
  // Hash de dedupe pra import em massa de planilha legada. Únicidade
  // garantida por (organization_id, import_hash) quando não-null.
  importHash            String?  @map("import_hash")
  // Assinatura SIMPLIFICADA do cliente na finalização da OS (sem certificado).
  // Só comprovação visual de retirada/aprovação — não tem hash de integridade
  // como o espelho do ponto. PNG via canvas na tela touch ou mobile do cliente.
  customerSignatureUrl String?  @map("customer_signature_url")
  customerSignedAt     DateTime? @map("customer_signed_at")
  customerSignatureIp  String?  @map("customer_signature_ip")
  // Grade/modelo fixo do pedido (gráfica): lista de modelos com tamanhos
  // permitidos. null/[] = sem grade (tamanho texto livre, comportamento antigo).
  sizeGrade            Json?     @map("size_grade")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @default(now()) @map("updated_at")

  items    ProductionOrderItem[]
  files    ProductionOrderFile[]
  reviews  ProductionArtReview[]
  roster   ProductionOrderRoster[]
  fabrics  ProductionOrderFabric[]
  payments ProductionPayment[]
  batch    ProductionBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)

  @@index([organizationId, status, dueDate])
  @@index([organizationId, artStatus])
  @@index([batchId])
  @@index([organizationId, assignedSupplierId, status])
  @@map("production_orders")
}

model ProductionBatch {
  id               String   @id @default(uuid()) @db.Uuid
  organizationId   String   @map("organization_id") @db.Uuid
  storeId          String?  @map("store_id") @db.Uuid
  name             String
  status           String   @default("aberto")
  notes            String?
  createdByUserId  String?  @map("created_by_user_id") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @default(now()) @map("updated_at")

  orders ProductionOrder[]

  @@index([organizationId, status, createdAt])
  @@map("production_batches")
}

model ProductionOrderRoster {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  orderId         String   @map("order_id") @db.Uuid
  playerName      String   @map("player_name")
  number          String?
  size            String?
  modelKey        String?  @map("model_key")
  qty             Int      @default(1)
  notes           String?
  position        Int      @default(0)
