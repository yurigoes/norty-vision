# Copie pra .env e preencha. O setup.sh lê estas variáveis pra gerar os configs.

# Domínio do PABX (DNS A apontando pra ESTE servidor, "DNS only" / sem proxy CF):
VOIP_DOMAIN=voip.yugochat.com.br

# IPv4 PÚBLICO deste servidor (não CGNAT). Usado no coturn/FreeSWITCH p/ mídia.
PUBLIC_IP=203.0.113.10

# URL pública da API do yugo (na VPS local, via Cloudflare). O FreeSWITCH consulta
# aqui (mod_xml_curl) p/ auth e roteamento dos ramais:
API_URL=https://yugochat.com.br

# Segredo combinado com a API (MESMO valor de VOIP_FS_SECRET no .env.production do yugo).
VOIP_FS_SECRET=TROQUE_ESTE_SEGREDO

# Credenciais do coturn (use as MESMAS em VOIP_TURN_USER/PASS no .env.production do yugo).
TURN_USER=yugo
TURN_PASS=TROQUE_ESTA_SENHA

# ---- Trunk SIP pra PSTN (números reais) — opcional ----
# Configurando aqui, o softphone passa a discar pra números (ex.: 7131800845) e a
# operadora entrega na rede pública. Em branco = só ramais internos (sem PSTN).
# Use o nome de gateway que combinar com VOIP_TRUNK_NAME do yugo (default yugo-trunk).
TRUNK_NAME=yugo-trunk
TRUNK_HOST=
TRUNK_USER=
TRUNK_PASS=
