# coturn (TURN/STUN) do PABX externo — gerado pelo setup.sh a partir do .env.
listening-port=3478
tls-listening-port=5349
fingerprint
lt-cred-mech
# usuário estático dos ramais WebRTC (mesmo em VOIP_TURN_USER/PASS da API):
user=__TURN_USER__:__TURN_PASS__
realm=__VOIP_DOMAIN__
# IP público (servidor tem IPv4 real):
external-ip=__PUBLIC_IP__
# faixa de mídia relayada (libere no firewall UDP):
min-port=49152
max-port=65535
# segurança
no-cli
no-multicast-peers
no-tlsv1
no-tlsv1_1
