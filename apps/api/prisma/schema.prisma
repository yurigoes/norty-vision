// Vendas históricas (importadas do legado) — só p/ controle/relatório.
// ===== CENTRAL DE ATENDIMENTO / CRM (Fase A) =====
model CrmLead {
  id                  String   @id @default(uuid()) @db.Uuid
  organizationId      String   @map("organization_id") @db.Uuid
  storeId             String?  @map("store_id") @db.Uuid
  customerId          String?  @map("customer_id") @db.Uuid
  conversationId      String?  @map("conversation_id") @db.Uuid
  name                String
  phone               String?
  email               String?
  source              String   @default("manual")
  stage               String   @default("novo")
  status              String   @default("aberto")
  ownerMembershipId   String?  @map("owner_membership_id") @db.Uuid
  score               Int      @default(0)
  lostReason          String?  @map("lost_reason")
  tabulation          String?
  protocol            String?
  tags                String[] @default([])
  nextActionAt        DateTime? @map("next_action_at")
  lastEventAt         DateTime @default(now()) @map("last_event_at")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @default(now()) @map("updated_at")
  events              CrmLeadEvent[]
  tasks               CrmTask[]
  @@index([organizationId, stage, lastEventAt])
  @@index([organizationId, ownerMembershipId])
  @@index([organizationId, phone])
  @@index([organizationId, status])
  @@map("crm_lead")
}

model CrmLeadEvent {
  id                  String   @id @default(uuid()) @db.Uuid
  organizationId      String   @map("organization_id") @db.Uuid
  leadId              String   @map("lead_id") @db.Uuid
  kind                String
  title               String
  body                String?
  authorMembershipId  String?  @map("author_membership_id") @db.Uuid
  refType             String?  @map("ref_type")
  refId               String?  @map("ref_id") @db.Uuid
  tabulation          String?
  protocol            String?
  createdAt           DateTime @default(now()) @map("created_at")
  lead                CrmLead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  @@index([leadId, createdAt])
  @@map("crm_lead_event")
}

model CrmTask {
  id                  String   @id @default(uuid()) @db.Uuid
  organizationId      String   @map("organization_id") @db.Uuid
  leadId              String   @map("lead_id") @db.Uuid
  title               String
  dueAt               DateTime? @map("due_at")
  ownerMembershipId   String?  @map("owner_membership_id") @db.Uuid
  doneAt              DateTime? @map("done_at")
  createdAt           DateTime @default(now()) @map("created_at")
  lead                CrmLead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  @@index([organizationId, ownerMembershipId, dueAt])
  @@index([leadId])
  @@map("crm_task")
}

