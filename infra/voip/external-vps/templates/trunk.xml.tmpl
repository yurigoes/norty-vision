<include>
  <!-- Trunk SIP do yugo — gera registro com a operadora pra fazer/receber
       chamadas PSTN. Gerado pelo setup.sh a partir do .env (VOIP_TRUNK_*). -->
  <gateway name="__TRUNK_NAME__">
    <param name="username"            value="__TRUNK_USER__"/>
    <param name="auth-username"       value="__TRUNK_USER__"/>
    <param name="password"            value="__TRUNK_PASS__"/>
    <param name="realm"               value="__TRUNK_HOST__"/>
    <param name="proxy"               value="__TRUNK_HOST__"/>
    <param name="register"            value="true"/>
    <param name="register-transport"  value="udp"/>
    <param name="expire-seconds"      value="600"/>
    <param name="ping"                value="30"/>
    <param name="retry-seconds"       value="30"/>
    <param name="caller-id-in-from"   value="true"/>
    <param name="extension-in-contact" value="true"/>
    <variables>
      <variable name="domain_name" value="__TRUNK_HOST__"/>
    </variables>
  </gateway>
</include>
