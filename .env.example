# ==============================================================================
# yugo-platform — variaveis de ambiente (template)
# Copie para .env e preencha. NUNCA commite .env de verdade.
# ==============================================================================

NODE_ENV=development
TZ=America/Sao_Paulo

# --- API ---
API_PORT=3001
API_PUBLIC_URL=http://localhost:3001
WEB_PUBLIC_URL=http://localhost:3000

# --- Database (Postgres) ---
# Em prod, gere as senhas com: openssl rand -base64 32
DATABASE_URL=postgresql://yugo:CHANGE_ME@localhost:5432/yugo?schema=public
DATABASE_URL_DIRECT=postgresql://yugo:CHANGE_ME@localhost:5432/yugo?schema=public

# --- Redis (cache + filas BullMQ) ---
REDIS_URL=redis://localhost:6379

# --- Auth ---
# Gere com: openssl rand -base64 64
AUTH_SECRET=CHANGE_ME_GENERATE_LONG_RANDOM
AUTH_COOKIE_DOMAIN=localhost
# rotacao de chaves JWT (EdDSA) - gerar com scripts/generate-jwt-keys.ts
JWT_PRIVATE_KEY_PATH=./secrets/jwt-private.pem
JWT_PUBLIC_KEY_PATH=./secrets/jwt-public.pem

# --- Email (transacional) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="yugo-platform <no-reply@yugochat.com.br>"

# --- WhatsApp / Evolution API ---
EVOLUTION_API_URL=https://evolution.yugochat.com.br
EVOLUTION_API_KEY=

# --- Storage (MinIO/S3) ---
STORAGE_ENDPOINT=https://s3.yugochat.com.br
STORAGE_PUBLIC_URL=https://s3.yugochat.com.br
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET=yugo-platform
STORAGE_REGION=us-east-1
STORAGE_INCLUDE_BUCKET_IN_URL=true

# --- Pagamentos (Mercado Pago) ---
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_WEBHOOK_SECRET=

# --- NLU fallback (Anthropic) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- IA Fase 4: modelos LOCAIS (open-source, Ollama/vLLM) ---
# Fallback de plataforma rodando na própria infra (dado não sai daqui, sem cota).
# Suba o overlay: docker compose -f docker-compose.prod.yml -f docker-compose.ai.yml up -d
LOCAL_AI_URL=
LOCAL_AI_MODEL=llama3.1:8b
# LOCAL_AI_KEY=                       # opcional (vLLM/LM Studio com auth)
OLLAMA_PULL=llama3.1:8b bge-m3        # modelos baixados no boot do Ollama

# --- IA Fase 2b: embeddings p/ RAG semântico (pgvector) ---
# Aponte pro Ollama local (recomendado) ou qualquer API OpenAI-compatible.
EMBEDDINGS_URL=
EMBEDDINGS_MODEL=bge-m3
EMBEDDINGS_DIM=1024
# EMBEDDINGS_API_KEY=

# --- Observabilidade ---
SENTRY_DSN=
LOG_LEVEL=info

# --- Feature flags ---
ENABLE_MFA=true
ENABLE_AUDIT_LOG=true
