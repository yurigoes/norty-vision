# ==============================================================================
# .gdrive.env  —  credenciais do Google Drive pro backup offsite.
# Copie para infra/docker/.gdrive.env e preencha. NUNCA versione o arquivo real.
#
# Como obter (passo a passo no README do backup):
#   1. console.cloud.google.com -> novo projeto -> ative a "Google Drive API".
#   2. Tela de consentimento OAuth (External) -> adicione seu email como "test user".
#   3. Credenciais -> Criar -> ID do cliente OAuth -> tipo "App para computador".
#      -> copie Client ID e Client Secret.
#   4. Pegue o REFRESH TOKEN no OAuth Playground (developers.google.com/oauthplayground):
#        engrenagem -> "Use your own OAuth credentials" (cola client id/secret)
#        escopo: https://www.googleapis.com/auth/drive
#        Authorize -> Exchange authorization code for tokens -> copie o "refresh_token".
#   5. Crie uma pasta no seu Drive (ex.: "yugo-backups"), abra ela e copie o
#      ID da URL: drive.google.com/drive/folders/<ESTE_ID>
# ==============================================================================

GDRIVE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GDRIVE_CLIENT_SECRET=xxxxxxxx
GDRIVE_REFRESH_TOKEN=1//xxxxxxxx
GDRIVE_FOLDER_ID=xxxxxxxx

# quantos backups manter NA NUVEM (ao subir o 5º, apaga o 1º). Default 4.
GDRIVE_KEEP=4
