# ==============================================================================
# Norty Vision — produção (.env.norty)
# NUNCA commitar este arquivo. Gere via ../scripts/norty-generate-secrets.sh
# ==============================================================================

# --- domínio (tunnel; sem ACME/Let's Encrypt aqui) ---
NORTY_BASE_DOMAIN=vision.norty.com.br

# --- Postgres (container nv-postgres) ---
POSTGRES_DB=norty_vision
POSTGRES_USER=norty
POSTGRES_PASSWORD=CHANGE_ME_RUN_GENERATE_SECRETS
# gerados/gravados pelo norty-db-apply.sh (roles yugo_app/yugo_migrator no SQL):
# YUGO_APP_PASSWORD=
# YUGO_MIGRATOR_PASSWORD=

# --- Redis (container nv-redis) ---
REDIS_PASSWORD=CHANGE_ME_RUN_GENERATE_SECRETS

# --- MinIO (container nv-minio) ---
MINIO_ROOT_USER=norty-admin
MINIO_ROOT_PASSWORD=CHANGE_ME_RUN_GENERATE_SECRETS
MINIO_BUCKET=norty-vision

# --- Auth ---
AUTH_SECRET=CHANGE_ME_RUN_GENERATE_SECRETS

# --- Plataforma ---
PLATFORM_ORG_SLUG=norty-vision
RUNBOOK_PASSWORD=CHANGE_ME_RUN_GENERATE_SECRETS

# --- Norty Vision: identidade + API de licenciamento (/api/norty/v1) ---
NORTY_SYSTEM_NAME=Norty Vision
# Token estático Bearer que o Norty (Sistemas→Gerenciar) usa pra chamar a API.
NORTY_LICENSE_TOKEN=nvlic_62e5b799c6e321c681bfb5e919a2b7754784e5a9580570c606ee4a487b051c7a

# --- Cloudflare Tunnel (PREENCHER MANUALMENTE) ---
# Token do tunnel PRÓPRIO do Norty Vision (Cloudflare -> Zero Trust -> Networks
# -> Tunnels). Mapeie os hostnames vision.norty.com.br e *.vision.norty.com.br
# pro serviço http://nv-caddy:80 na config do tunnel.
NORTY_CLOUDFLARED_TOKEN=

# --- SMTP (opcional) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Norty Vision <no-reply@vision.norty.com.br>

# --- Anthropic (opcional; IA fallback) ---
ANTHROPIC_API_KEY=
