// ===== SUPORTE AO SISTEMA (empresa → master) =====
model PlatformSupportTicket {
  id                    String   @id @default(uuid()) @db.Uuid
  organizationId        String   @map("organization_id") @db.Uuid
  storeId               String?  @map("store_id") @db.Uuid
  requesterUserId       String?  @map("requester_user_id") @db.Uuid
  requesterMembershipId String?  @map("requester_membership_id") @db.Uuid
  requesterName         String?  @map("requester_name")
  requesterRole         String?  @map("requester_role")
  category              String   @default("duvida")
  subject               String
  priority              String   @default("normal")
  status                String   @default("aberto")
  channel               String   @default("portal")
  aiHandled             Boolean  @default(false) @map("ai_handled")
  aiSummary             String?  @map("ai_summary")
  resolution            String?
  resolvedByMaster      String?  @map("resolved_by_master") @db.Uuid
  resolvedAt            DateTime? @map("resolved_at")
  shortCode             String?  @unique @map("short_code")
