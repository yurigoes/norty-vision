# ==============================================================================
# yugo-platform - producao (.env.production)
# NUNCA commitar este arquivo. Gere via ../scripts/generate-secrets.sh
# ==============================================================================

# --- dominio + Let's Encrypt ---
DOMAIN=yugochat.com.br
ACME_EMAIL=admin@yugochat.com.br

# --- Postgres ---
POSTGRES_DB=yugo
POSTGRES_USER=yugo
POSTGRES_PASSWORD=CHANGE_ME_RUN_GENERATE_SECRETS

# --- Redis ---
REDIS_PASSWORD=CHANGE_ME_RUN_GENERATE_SECRETS

# --- MinIO ---
MINIO_ROOT_USER=yugo-admin
MINIO_ROOT_PASSWORD=CHANGE_ME_RUN_GENERATE_SECRETS
MINIO_BUCKET=yugo-platform

# --- Auth (preenchido quando a app subir) ---
AUTH_SECRET=CHANGE_ME_RUN_GENERATE_SECRETS

# --- Anthropic (NLU fallback) ---
ANTHROPIC_API_KEY=
